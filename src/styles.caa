@property --glow { syntax: '<color>'; inherits: true; initial-value: rgba(114,212,198,.1); }
:root{--bg:#080908;--surface:rgba(255,255,255,.038);--line:rgba(255,255,255,.1);--line2:rgba(255,255,255,.18);--text:#efede7;--muted:#98938c;--quiet:#5e5a55;--teal:#73d6c8;--sand:#cbb898;--gold:#d6b36d;--sage:#aab89c;--display:'Playfair Display',Georgia,serif;--body:Inter,Arial,sans-serif;--ease:cubic-bezier(.16,1,.3,1)}[data-theme=light]{--bg:#f3f0eb;--surface:rgba(20,18,14,.04);--line:rgba(20,18,14,.11);--line2:rgba(20,18,14,.2);--text:#191713;--muted:#6d675f;--quiet:#aaa49c}*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:var(--bg);color:var(--text);font-family:var(--body);font-size:16px}button,a{font:inherit;color:inherit}button{cursor:pointer}button:disabled{opacity:.25;cursor:not-allowed}.grain{position:fixed;z-index:10;inset:0;pointer-events:none;opacity:.026;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E")}.atmosphere{position:fixed;z-index:-1;inset:0;overflow:hidden;pointer-events:none}.atmosphere i,.atmosphere b,.atmosphere em{position:absolute;border-radius:50%;filter:blur(80px);transition:background 1s var(--ease)}.atmosphere i{width:62vw;height:62vw;top:-25vw;right:-15vw}.atmosphere b{width:42vw;height:42vw;bottom:3%;left:-20vw}.atmosphere em{width:30vw;height:30vw;top:40%;left:42%;opacity:.5}.a-teal i{background:rgba(115,214,200,.12)}.a-teal b{background:rgba(203,184,152,.07)}.a-sand i{background:rgba(203,184,152,.13)}.a-sand b{background:rgba(115,214,200,.07)}.a-gold i{background:rgba(214,179,109,.13)}.a-gold b{background:rgba(115,214,200,.08)}.a-sage i{background:rgba(170,184,156,.13)}.a-sage b{background:rgba(203,184,152,.08)}main{min-height:100vh;overflow:hidden}.nav{width:min(1180px,calc(100% - 48px));height:80px;margin:auto;display:flex;align-items:center;justify-content:space-between;position:relative;z-index:20}.brand{display:flex;align-items:center;gap:10px;text-decoration:none;font-size:13px;font-weight:600;letter-spacing:.02em}.mark{width:30px;height:30px;border:1px solid var(--line2);border-radius:9px;display:grid;place-items:center;position:relative;overflow:hidden;background:var(--surface);font-family:var(--display)}.mark i{font-style:italic;color:var(--teal);font-size:16px;transform:translateX(2px)}.mark span{color:var(--sand);font-size:16px;transform:translateX(-2px)}.nav-center{display:flex;align-items:center;gap:9px;color:var(--quiet);font-size:11px;letter-spacing:.12em;text-transform:uppercase}.nav-center i{width:5px;height:5px;border-radius:50%;background:var(--teal);box-shadow:0 0 10px var(--teal)}.nav-actions{display:flex;gap:8px}.theme,.menu-button{width:36px;height:36px;border-radius:50%;border:1px solid var(--line);background:var(--surface);display:grid;place-items:center;color:var(--muted);transition:.25s}.theme:hover,.menu-button:hover{border-color:var(--line2);color:var(--text)}.room-menu{position:fixed;right:max(24px,calc((100vw - 1180px)/2));top:72px;width:280px;padding:15px;z-index:30;border:1px solid var(--line);border-radius:18px;background:color-mix(in srgb,var(--bg) 84%,transparent);backdrop-filter:blur(24px);box-shadow:0 18px 50px rgba(0,0,0,.25);animation:menu .3s var(--ease)}@keyframes menu{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}.menu-head{display:flex;justify-content:space-between;padding:4px 5px 12px;color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.12em}.menu-head small{color:var(--quiet)}.room-menu button{width:100%;border:0;background:transparent;border-radius:10px;padding:12px 8px;text-align:left;color:var(--muted);display:flex;gap:10px;align-items:center;transition:.2s}.room-menu button b{font:400 16px var(--display);color:var(--quiet)}.room-menu button span{font-size:13px;flex:1}.room-menu button:hover,.room-menu button.selected{background:var(--surface);color:var(--text)}.room-menu button.selected b{color:var(--teal)}.arrival{width:min(1180px,calc(100% - 48px));min-height:calc(100vh - 80px);margin:auto;display:grid;grid-template-columns:1fr .78fr;align-items:center;gap:6vw;padding:7vh 0 11vh}.arrival-copy{position:relative;z-index:1;animation:up .9s var(--ease) .1s both}.overline{color:var(--muted);font-size:10px;letter-spacing:.16em;text-transform:uppercase;display:flex;gap:8px;align-items:center;margin:0 0 24px}.overline span{width:6px;height:6px;border-radius:50%;background:var(--teal);box-shadow:0 0 14px var(--teal)}h1,h2{font-family:var(--display);font-weight:400;letter-spacing:-.045em;margin:0}h1{font-size:clamp(4rem,7.7vw,7.7rem);line-height:.86;max-width:8ch}h1 em,h2 em{font-style:italic;color:var(--sand)}.arrival-sub{color:var(--muted);max-width:290px;line-height:1.6;font-size:15px;margin:26px 0}.enter,.room-cta{border:0;text-decoration:none;display:inline-flex;align-items:center;gap:11px;padding:14px 19px;border-radius:999px;background:var(--text);color:var(--bg);font-size:13px;font-weight:600;transition:transform .3s var(--ease),box-shadow .3s}.enter:hover,.room-cta:hover{transform:translateY(-2px);box-shadow:0 12px 28px rgba(0,0,0,.25)}.front-door{height:490px;position:relative;display:flex;align-items:center;justify-content:center;animation:up 1s var(--ease) .25s both}.door-frame{height:390px;width:265px;border:1px solid var(--line2);border-radius:135px 135px 4px 4px;position:relative;overflow:hidden;background:linear-gradient(160deg,var(--surface),transparent);box-shadow:inset 0 0 80px rgba(255,255,255,.025),0 20px 80px rgba(0,0,0,.15)}.door-light{position:absolute;width:240px;height:300px;left:12px;top:75px;border-radius:50%;background:radial-gradient(ellipse,rgba(115,214,200,.24),rgba(203,184,152,.08) 35%,transparent 68%);filter:blur(18px);animation:pulse 5s ease-in-out infinite}.door-line{position:absolute;left:50%;width:1px;background:linear-gradient(transparent,var(--line2),transparent)}.l1{height:260px;top:50px}.l2{height:240px;top:80px;transform:rotate(25deg)}.l3{height:240px;top:80px;transform:rotate(-25deg)}.door-number{position:absolute;bottom:20px;left:22px;color:var(--muted);font-size:10px;letter-spacing:.15em}.door-caption{position:absolute;right:-20px;bottom:38px;font:italic 20px/1.05 var(--display);color:var(--text);background:color-mix(in srgb,var(--bg) 72%,transparent);backdrop-filter:blur(5px);padding:12px}@keyframes pulse{50%{transform:scale(1.12);opacity:.7}}@keyframes up{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:none}}.experience{width:min(1180px,calc(100% - 48px));margin:auto;padding:105px 0}.room-track{height:28px;display:flex;align-items:center;margin-bottom:27px}.room-track button{width:25%;height:1px;border:0;background:var(--line);position:relative;padding:0;text-align:left}.room-track button span{position:absolute;top:50%;transform:translateY(-50%);left:0;width:29px;height:29px;border:1px solid var(--line);border-radius:50%;background:var(--bg);color:var(--quiet);font:11px var(--body);display:grid;place-items:center;z-index:2;transition:.3s}.room-track button:last-child{width:0}.room-track button.on{background:linear-gradient(90deg,var(--teal),var(--line))}.room-track button.on span{color:var(--teal);border-color:var(--teal);box-shadow:0 0 20px rgba(115,214,200,.2)}.room-track button.done span{color:var(--bg);background:var(--teal);border-color:var(--teal)}.room-shell{border:1px solid var(--line);border-radius:27px;background:linear-gradient(130deg,var(--surface),transparent);backdrop-filter:blur(14px);overflow:hidden}.room-meta{display:flex;justify-content:space-between;align-items:flex-end;padding:23px 29px;border-bottom:1px solid var(--line)}.room-meta>div{font-family:var(--display)}.room-num{font-size:25px;color:var(--text)}.room-total{font-size:15px;color:var(--quiet)}.room-meta p{margin:0;font-size:10px;color:var(--muted);letter-spacing:.15em;text-transform:uppercase}.room-content{min-height:465px;display:grid;grid-template-columns:.96fr 1.04fr;align-items:stretch;animation:fade .5s var(--ease)}@keyframes fade{from{opacity:0;filter:blur(4px)}to{opacity:1;filter:none}}.room-copy{padding:clamp(34px,5vw,66px);display:flex;flex-direction:column;align-items:flex-start;justify-content:center}.room-copy h2{font-size:clamp(2.7rem,5vw,5.2rem);line-height:.9;max-width:8ch}.room-copy>p{font-size:14px;line-height:1.65;color:var(--muted);max-width:38ch;margin:24px 0}.room-copy small{font-size:11px;color:var(--quiet);margin-top:12px}.room-cta{background:var(--text)}.room-footer{height:65px;border-top:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;padding:0 29px}.room-footer button{border:0;background:transparent;display:flex;align-items:center;gap:7px;color:var(--muted);font-size:12px;transition:color .2s}.room-footer button:not(:disabled):hover{color:var(--text)}.room-footer span{font-size:10px;color:var(--quiet);letter-spacing:.13em;text-transform:uppercase}.art{border-left:1px solid var(--line);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;min-height:350px;background:radial-gradient(ellipse at center,var(--surface),transparent 68%)}.art-label{position:absolute;top:23px;right:25px;color:var(--quiet);font-size:10px;letter-spacing:.14em;text-transform:uppercase}.art-start .orbit{position:absolute;border-radius:50%;border:1px solid var(--line)}.o-one{width:270px;height:270px}.o-two{width:390px;height:390px;border-style:dashed!important;animation:turn 22s linear infinite}.core{width:100px;height:100px;border:1px solid rgba(115,214,200,.35);background:rgba(115,214,200,.06);border-radius:50%;display:flex;align-items:center;justify-content:center;position:relative;box-shadow:0 0 70px rgba(115,214,200,.1)}.core i{font:italic 46px var(--display);color:var(--teal)}.core small{position:absolute;bottom:20px;font:7px var(--body);letter-spacing:.12em;text-align:center;color:var(--muted)}.orbit-label{position:absolute;font-size:9px;letter-spacing:.14em;color:var(--muted)}.orbit-label.a{top:75px}.orbit-label.b{bottom:83px;left:26%}.orbit-label.c{right:19%;top:48%}@keyframes turn{to{transform:rotate(360deg)}}.art-setup{gap:12px;flex-wrap:wrap;align-content:center;padding:50px}.flow-card{width:94px;height:112px;border:1px solid var(--line2);border-radius:13px;background:var(--surface);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:9px;position:relative;z-index:1}.flow-card b{font:italic 24px var(--display);color:var(--sand)}.flow-card span{font-size:10px;color:var(--muted)}.flow-line{width:20px;height:1px;background:var(--sand);opacity:.7}.flow-status{position:absolute;bottom:49px;width:calc(100% - 100px);height:32px;border:1px solid var(--line);border-radius:999px;display:flex;gap:7px;align-items:center;justify-content:center;color:var(--quiet);font-size:8px;letter-spacing:.13em}.flow-status i{width:5px;height:5px;background:var(--teal);border-radius:50%;box-shadow:0 0 9px var(--teal)}.art-next .slot-device{width:246px;height:320px;border:1px solid rgba(214,179,109,.35);border-radius:18px;background:linear-gradient(145deg,rgba(255,255,255,.09),rgba(255,255,255,.025));padding:18px;position:relative;z-index:2;box-shadow:0 25px 60px rgba(0,0,0,.3)}.device-top{display:flex;justify-content:space-between;font:20px var(--display)}.device-top em{font-style:italic;color:var(--teal)}.device-top i{width:7px;height:7px;border-radius:50%;background:var(--teal);box-shadow:0 0 10px var(--teal)}.device-calendar{margin-top:25px;height:175px;border:1px solid var(--line);border-radius:10px;padding:15px}.device-calendar b{font-size:10px;font-weight:500}.device-calendar div{display:flex;gap:5px;margin:18px 0 13px}.device-calendar i{height:43px;flex:1;border-radius:4px;background:var(--surface);border:1px solid var(--line)}.device-calendar i:nth-child(2),.device-calendar i:nth-child(4){background:rgba(115,214,200,.18);border-color:rgba(115,214,200,.3)}.device-calendar small{font-size:9px;color:var(--quiet)}.device-book{margin-top:13px;background:var(--teal);color:#0b1312;padding:10px 12px;border-radius:8px;font-size:10px;font-weight:600;display:flex;justify-content:space-between}.ring{position:absolute;border-radius:50%;border:1px solid rgba(214,179,109,.18)}.r1{width:380px;height:380px}.r2{width:510px;height:510px;border-style:dashed}.art-funding .fund-circle{width:142px;height:142px;border:1px solid rgba(170,184,156,.45);border-radius:50%;background:rgba(170,184,156,.08);display:grid;place-items:center;z-index:1;box-shadow:0 0 70px rgba(170,184,156,.12)}.fund-circle span{font:italic 70px var(--display);color:var(--sage)}.fund-rays{position:absolute;width:390px;height:390px;animation:turn 32s linear infinite}.fund-rays i{position:absolute;top:0;left:50%;transform-origin:50% 195px!important;width:1px;height:33px;background:linear-gradient(var(--sage),transparent);opacity:.6}.fund-card{position:absolute;right:28px;bottom:35px;width:195px;padding:15px;border:1px solid var(--line);border-radius:12px;background:color-mix(in srgb,var(--bg) 72%,transparent);backdrop-filter:blur(12px);display:flex;flex-direction:column;gap:5px}.fund-card b{font:400 15px/1.1 var(--display)}.fund-card span{font-size:9px;color:var(--muted)}.map{width:min(1180px,calc(100% - 48px));margin:0 auto;padding:90px 0 120px;display:grid;grid-template-columns:.75fr 1.25fr;gap:6vw;align-items:end}.map-title h2{font-size:clamp(2.5rem,4vw,4.4rem);line-height:.95}.map-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}.map-card{padding:18px;border-radius:15px;border:1px solid var(--line);background:var(--surface);color:var(--text);text-align:left;min-height:145px;display:flex;flex-direction:column;transition:.3s var(--ease)}.map-card:hover{transform:translateY(-4px);border-color:var(--line2);background:var(--surface)}.map-card>div{display:flex;justify-content:space-between;color:var(--muted);font-size:10px;letter-spacing:.12em;text-transform:uppercase}.map-card b{font:17px var(--display);color:var(--quiet)}.map-card p{font:15px/1.2 var(--display);margin:auto 0 14px;max-width:12ch}.map-card>svg{align-self:flex-end;color:var(--muted)}.map-card.teal:hover{box-shadow:0 14px 35px rgba(115,214,200,.08)}.map-card.sand:hover{box-shadow:0 14px 35px rgba(203,184,152,.08)}.map-card.gold:hover{box-shadow:0 14px 35px rgba(214,179,109,.08)}.map-card.sage:hover{box-shadow:0 14px 35px rgba(170,184,156,.08)}footer{width:min(1180px,calc(100% - 48px));margin:auto;border-top:1px solid var(--line);padding:25px 0 35px;display:flex;align-items:center;justify-content:space-between;color:var(--quiet);font-size:10px}footer>div{display:flex;align-items:center;gap:8px;color:var(--muted);font-size:12px;font-weight:600}footer .mark{width:25px;height:25px;border-radius:7px}footer p{margin:0}@media(max-width:720px){.nav{width:calc(100% - 32px);height:70px}.nav-center{display:none}.room-menu{right:16px;top:62px}.arrival{width:calc(100% - 40px);min-height:calc(100vh - 70px);display:flex;flex-direction:column;justify-content:center;align-items:flex-start;padding:5vh 0 8vh;gap:35px}.front-door{align-self:center;height:270px;transform:scale(.67);margin:-35px 0}.experience,.map{width:calc(100% - 32px);padding:65px 0}.room-content{grid-template-columns:1fr}.art{border-left:0;border-top:1px solid var(--line);min-height:300px}.room-copy{padding:38px 25px}.room-copy h2{font-size:3.1rem}.room-meta{padding:19px 25px}.room-footer{padding:0 20px}.map{grid-template-columns:1fr;gap:35px}.map-grid{gap:8px}footer{width:calc(100% - 32px);flex-wrap:wrap;gap:16px}footer p:last-child{width:100%}.art-start .o-two{width:330px;height:330px}.fund-card{right:14px;bottom:18px}.flow-card{width:82px;height:95px}.flow-line{width:10px}}@media(prefers-reduced-motion:reduce){*,*:before,*:after{animation-duration:.01ms!important;animation-iteration-count:1!important;scroll-behavior:auto!important;transition-duration:.01ms!important}}
